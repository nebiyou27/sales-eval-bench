{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tenacious-Bench Task",
  "type": "object",
  "$defs": {
    "judgeDimension": {
      "type": "string",
      "enum": [
        "output_validity",
        "ai_maturity_consistency",
        "gap_condescension",
        "signal_grounding",
        "style_guide_adherence",
        "next_step_quality"
      ]
    },
    "retrievalProvenance": {
      "type": "object",
      "required": ["url", "retrieved_at", "source_type"],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "minLength": 1
        },
        "retrieved_at": {
          "type": "string",
          "format": "date-time"
        },
        "source_type": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    }
  },
  "required": [
    "task_id",
    "partition",
    "source_mode",
    "difficulty",
    "failure_dimension",
    "input",
    "candidate_output",
    "ground_truth",
    "rubric",
    "scoring_config",
    "metadata"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "partition": {
      "type": "string",
      "enum": ["train", "dev", "held_out"]
    },
    "source_mode": {
      "type": "string",
      "enum": ["trace_derived", "programmatic", "synthetic", "human_authored"]
    },
    "difficulty": {
      "type": "string",
      "enum": ["easy", "medium", "hard"]
    },
    "failure_dimension": {
      "type": "string",
      "enum": [
        "output_validity",
        "ai_maturity_consistency",
        "gap_condescension",
        "signal_grounding",
        "style_guide_adherence",
        "next_step_quality"
      ]
    },
    "input": {
      "type": "object",
      "minProperties": 1
    },
    "candidate_output": {
      "type": "string",
      "minLength": 1
    },
    "ground_truth": {
      "type": "object",
      "minProperties": 1
    },
    "rubric": {
      "type": "object",
      "required": ["expected_terms", "forbidden_terms"],
      "properties": {
        "expected_terms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "forbidden_terms": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "scoring_config": {
      "type": "object",
      "required": ["deterministic_dimensions"],
      "properties": {
        "deterministic_dimensions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "output_nonempty",
              "ai_maturity_keyword_present",
              "banned_condescension_absent",
              "expected_signal_term_present",
              "forbidden_terms_absent",
              "buyer_next_step_keyword_present"
            ]
          },
          "minItems": 1
        },
        "judge_dimensions": {
          "type": "array",
          "items": { "$ref": "#/$defs/judgeDimension" },
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    },
    "metadata": {
      "type": "object",
      "required": ["probe_id", "source_artifact"],
      "properties": {
        "probe_id": {
          "type": "string",
          "pattern": "^P[0-9]{2}$"
        },
        "source_artifact": {
          "type": "string",
          "minLength": 1
        },
        "retrieval_provenance": {
          "$ref": "#/$defs/retrievalProvenance"
        }
      },
      "additionalProperties": true,
      "minProperties": 2
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "source_mode": { "const": "synthetic" },
          "failure_dimension": { "const": "signal_grounding" }
        },
        "required": ["source_mode", "failure_dimension"]
      },
      "then": {
        "properties": {
          "metadata": {
            "required": ["retrieval_provenance"]
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
