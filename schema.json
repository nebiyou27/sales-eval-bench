{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tenacious-Bench Task",
  "type": "object",
  "$defs": {
    "judgeDimension": {
      "type": "string",
      "enum": [
        "output_validity",
        "ai_maturity_consistency",
        "gap_condescension",
        "signal_grounding",
        "style_guide_adherence",
        "next_step_quality"
      ]
    },
    "deterministicDimension": {
      "type": "string",
      "enum": [
        "output_nonempty",
        "subject_present_for_email",
        "max_body_words_respected",
        "max_subject_chars_respected",
        "ai_maturity_keyword_present",
        "banned_phrase_absent",
        "bench_term_absent",
        "banned_condescension_absent",
        "expected_signal_term_present",
        "forbidden_terms_absent",
        "buyer_next_step_keyword_present",
        "single_ask_only"
      ]
    },
    "toneMarker": {
      "type": "string",
      "enum": [
        "direct",
        "grounded",
        "honest",
        "professional",
        "non_condescending"
      ]
    },
    "signal": {
      "type": "object",
      "required": ["signal_type", "evidence", "confidence"],
      "properties": {
        "signal_type": {
          "type": "string",
          "enum": [
            "funding_event",
            "job_post_velocity",
            "layoff_event",
            "leadership_change",
            "competitor_gap",
            "ai_maturity",
            "bench_match",
            "pricing_scope",
            "prior_thread"
          ]
        },
        "evidence": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "retrievalProvenance": {
      "type": "object",
      "required": ["url", "retrieved_at", "source_type"],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "minLength": 1
        },
        "retrieved_at": {
          "type": "string",
          "format": "date-time"
        },
        "source_type": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    }
  },
  "required": [
    "task_id",
    "partition",
    "source_mode",
    "difficulty",
    "failure_dimension",
    "channel",
    "message_kind",
    "input",
    "candidate_output",
    "ground_truth",
    "rubric",
    "scoring_config",
    "metadata"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "partition": {
      "type": "string",
      "enum": ["train", "dev", "held_out"]
    },
    "source_mode": {
      "type": "string",
      "enum": ["trace_derived", "programmatic", "synthetic", "hand_authored"]
    },
    "difficulty": {
      "type": "string",
      "enum": ["easy", "medium", "hard"]
    },
    "failure_dimension": {
      "type": "string",
      "enum": [
        "output_validity",
        "ai_maturity_consistency",
        "gap_condescension",
        "signal_grounding",
        "style_guide_adherence",
        "next_step_quality"
      ]
    },
    "channel": {
      "type": "string",
      "enum": ["email", "linkedin_dm", "sms"]
    },
    "message_kind": {
      "type": "string",
      "enum": ["cold_outreach", "warm_reply", "reengagement"]
    },
    "input": {
      "type": "object",
      "required": [
        "prospect",
        "hiring_signal_brief",
        "bench_context",
        "prior_thread"
      ],
      "properties": {
        "prospect": {
          "type": "object",
          "required": ["company_name", "contact_role"],
          "properties": {
            "company_name": {
              "type": "string",
              "minLength": 1
            },
            "contact_role": {
              "type": "string",
              "minLength": 1
            },
            "company_stage": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "hiring_signal_brief": {
          "type": "object",
          "required": [
            "primary_segment",
            "signal_confidence",
            "signals"
          ],
          "properties": {
            "primary_segment": {
              "type": "string",
              "enum": [
                "segment_1_recently_funded",
                "segment_2_restructuring_cost",
                "segment_3_leadership_transition",
                "segment_4_capability_gap"
              ]
            },
            "signal_confidence": {
              "type": "string",
              "enum": ["low", "medium", "high"]
            },
            "signals": {
              "type": "array",
              "items": { "$ref": "#/$defs/signal" },
              "minItems": 1
            },
            "ai_maturity": {
              "type": "object",
              "properties": {
                "score": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 3
                },
                "confidence": {
                  "type": "string",
                  "enum": ["low", "medium", "high"]
                }
              },
              "required": ["score", "confidence"],
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "bench_context": {
          "type": "object",
          "required": [
            "supported_stacks",
            "capacity_commitment_allowed",
            "pricing_scope"
          ],
          "properties": {
            "supported_stacks": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1
            },
            "capacity_commitment_allowed": {
              "type": "boolean"
            },
            "pricing_scope": {
              "type": "string",
              "enum": [
                "public_bands_only",
                "route_specific_quote_to_human"
              ]
            }
          },
          "additionalProperties": true
        },
        "prior_thread": {
          "type": "object",
          "required": ["contacted_before", "summary"],
          "properties": {
            "contacted_before": {
              "type": "boolean"
            },
            "summary": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "candidate_output": {
      "type": "object",
      "required": ["body"],
      "properties": {
        "subject": {
          "type": "string",
          "minLength": 1
        },
        "body": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "ground_truth": {
      "type": "object",
      "required": ["expected_behavior", "target_decision"],
      "properties": {
        "expected_behavior": {
          "type": "string",
          "minLength": 1
        },
        "target_decision": {
          "type": "string",
          "enum": ["accept", "revise", "block"]
        },
        "failure_rationale": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "rubric": {
      "type": "object",
      "required": [
        "tone_markers",
        "expected_terms",
        "forbidden_terms",
        "banned_phrases",
        "max_body_words",
        "one_ask_required",
        "require_signal_reference",
        "confidence_aware_language"
      ],
      "properties": {
        "tone_markers": {
          "type": "array",
          "items": { "$ref": "#/$defs/toneMarker" },
          "minItems": 1,
          "uniqueItems": true
        },
        "expected_terms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "forbidden_terms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "banned_phrases": {
          "type": "array",
          "items": { "type": "string" }
        },
        "max_body_words": {
          "type": "integer",
          "minimum": 1
        },
        "max_subject_chars": {
          "type": "integer",
          "minimum": 1
        },
        "one_ask_required": {
          "type": "boolean"
        },
        "require_signal_reference": {
          "type": "boolean"
        },
        "confidence_aware_language": {
          "type": "boolean"
        },
        "forbid_bench_term": {
          "type": "boolean"
        },
        "allowed_channels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["email", "linkedin_dm", "sms"]
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    },
    "scoring_config": {
      "type": "object",
      "required": ["deterministic_dimensions"],
      "properties": {
        "deterministic_dimensions": {
          "type": "array",
          "items": { "$ref": "#/$defs/deterministicDimension" },
          "minItems": 1,
          "uniqueItems": true
        },
        "judge_dimensions": {
          "type": "array",
          "items": { "$ref": "#/$defs/judgeDimension" },
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    },
    "metadata": {
      "type": "object",
      "required": [
        "probe_id",
        "source_artifact",
        "style_guide_version"
      ],
      "properties": {
        "probe_id": {
          "type": "string",
          "pattern": "^P[0-9]{2}$"
        },
        "source_artifact": {
          "type": "string",
          "minLength": 1
        },
        "style_guide_version": {
          "type": "string",
          "minLength": 1
        },
        "retrieval_provenance": {
          "$ref": "#/$defs/retrievalProvenance"
        },
        "source_trace_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "channel": { "const": "email" }
        },
        "required": ["channel"]
      },
      "then": {
        "properties": {
          "candidate_output": {
            "required": ["subject", "body"]
          },
          "rubric": {
            "required": ["max_subject_chars"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "message_kind": { "const": "cold_outreach" }
        },
        "required": ["message_kind"]
      },
      "then": {
        "properties": {
          "rubric": {
            "properties": {
              "max_body_words": {
                "maximum": 120
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "message_kind": { "const": "warm_reply" }
        },
        "required": ["message_kind"]
      },
      "then": {
        "properties": {
          "rubric": {
            "properties": {
              "max_body_words": {
                "maximum": 200
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "message_kind": { "const": "reengagement" }
        },
        "required": ["message_kind"]
      },
      "then": {
        "properties": {
          "rubric": {
            "properties": {
              "max_body_words": {
                "maximum": 100
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "source_mode": { "const": "synthetic" },
          "failure_dimension": { "const": "signal_grounding" }
        },
        "required": ["source_mode", "failure_dimension"]
      },
      "then": {
        "properties": {
          "metadata": {
            "required": ["retrieval_provenance"]
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
